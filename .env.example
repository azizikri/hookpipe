# Hookpipe Configuration
# Copy to .env and adjust values

# Server
HOOKPIPE_HOST=0.0.0.0
HOOKPIPE_PORT=3000

# Database
HOOKPIPE_DB_PATH=./data/hookpipe.db

# Logging
HOOKPIPE_LOG_LEVEL=info

# Pipelines directory
HOOKPIPE_PIPELINES_DIR=./pipelines

# Plugins directory
HOOKPIPE_PLUGINS_DIR=./plugins
